Connect-MgGraph

#importing the CSV source which has the changes
$data = Import-Csv C:\Users\Public\GroupOwnerBulkUpdate.csv

foreach ($row in $data)
{
    #INFO in the Console
    Write-Host "Updating the Group :" $row.'GroupName' " Owner to " $row.'Owner' -ForegroundColor Yellow

    $groupname = $row.'GroupName'
    $username  = $row.'Owner'

    #Updating the Manager
    New-MgGroupOwner -GroupId (Get-MgGroup -filter "DisplayName eq '$groupname'").Id `
        -DirectoryObjectId (Get-MgUser -UserId $username).id

    #Completion info in the console for the specified row
    Write-Host "Updated." -ForegroundColor Green
}
